{
    "name": "mixvoip/claude-boost",
    "description": "One file. Zero commands. Makes Claude smart about your codebase. Any language. Any framework.",
    "type": "library",
    "license": "MIT",
    "keywords": ["claude", "ai", "codebase", "registry", "conventions", "safety", "developer-tools"],
    "authors": [
        {
            "name": "Umair Ali",
            "role": "Creator"
        }
    ],
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.0|^7.0",
        "symfony/process": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "ClaudeBoost\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ClaudeBoost\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ClaudeBoost\\ClaudeBoostServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
